# Copy this file to `.env.local` (same folder) and restart `pnpm --filter web dev`.
# Both variables are optional — the app runs fine with neither set.

# Gateway URL for Measured mode (Flagship Model|Measured toggle) and the Code Playground.
# Defaults to this if unset; only change it if the gateway runs somewhere else
# (e.g. a shared classroom server — see SETUP.md "For instructors").
NEXT_PUBLIC_VHPCE_API=http://localhost:8000

# Enables the server-side "Ask the AI" panel for everyone, without each student pasting
# a per-tab key in the UI. Get a key at https://console.anthropic.com/. Leave blank to
# rely on the in-UI "bring your own key" field instead.
ANTHROPIC_API_KEY=
